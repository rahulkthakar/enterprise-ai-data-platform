{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Events Schema",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "product_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": ["view", "cart", "purchase"]
    },
    "price": {
      "type": "number"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "device": {
      "type": "string"
    },
    "location": {
      "type": "string"
    }
  },
  "required": [
    "user_id",
    "product_id",
    "event_type",
    "price",
    "timestamp",
    "device",
    "location"
  ]
}